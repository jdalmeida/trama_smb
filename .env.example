# ─────────────────────────────────────────────────────────────
# Trama — variáveis de ambiente (copie para .env.local e preencha)
# ─────────────────────────────────────────────────────────────

# --- AI Gateway (Vercel) ---
# Local: crie a chave no dashboard da Vercel (AI Gateway) e cole aqui.
# Em produção na Vercel, o OIDC (VERCEL_OIDC_TOKEN) é injetado automaticamente.
AI_GATEWAY_API_KEY=

# Overrides opcionais de modelo (senão usa os defaults de src/ai/models.ts)
# MODEL_REASONING=anthropic/claude-sonnet-4.5
# MODEL_WORKER=anthropic/claude-sonnet-4.5
# MODEL_CHEAP=google/gemini-3.1-flash-lite

# --- Banco de dados (Neon via Vercel Marketplace) ---
# DATABASE_URL = conexão pooled (runtime).
# DATABASE_URL_UNPOOLED = conexão direta (migrações com drizzle-kit).
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# --- Auth (Clerk via Vercel Marketplace) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Busca web para as personas (opcional; só fontes públicas) ---
# Sem chave, a persona ainda funciona, mas sem resultados de busca em tempo real.
TAVILY_API_KEY=

# --- Omnichannel Meta (WhatsApp, Instagram, Messenger) ---
# Sem estas variáveis a aba "Canais" funciona em modo de SIMULAÇÃO (contas e
# mensagens de teste). Para conectar contas reais, configure o app na Meta —
# passo a passo em docs/omnichannel-setup.md.
META_APP_ID=
META_APP_SECRET=
# Token que VOCÊ define e cadastra no painel do webhook da Meta (qualquer string).
META_WEBHOOK_VERIFY_TOKEN=
# Opcional: id da configuração do Facebook Login for Business / Embedded Signup.
# Com ele, as permissões vêm da configuração; sem ele, usamos os scopes padrão.
META_LOGIN_CONFIG_ID=
# Versão da Graph API (default v21.0).
META_GRAPH_VERSION=v21.0
# Base pública do app para o redirect do OAuth (ex.: https://seuapp.com).
# Se vazio, é derivada da própria requisição.
META_OAUTH_REDIRECT_BASE=
